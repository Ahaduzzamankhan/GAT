{
  "name": "gat",
  "version": "1.0.0",
  "description": "Game Activity Tracker",
  "main": "dist/main/index.js",
  "author": "Fluxenite",
  "license": "MIT",

  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:backend\" \"npm run dev:electron\"",

    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:backend": "cd backend && go run .",
    "dev:electron": "wait-on tcp:5173 && electron .",

    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:backend": "call build-backend.bat",

    "build": "npm run build:backend && npm run build:renderer && npm run build:main",

    "electron": "electron .",
    "start": "npm run build && npm run electron",

    "dist": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:all": "npm run build && electron-builder -w"
  },

  "dependencies": {
    "framer-motion": "^11.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2"
  },

  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.0.1",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "wait-on": "^8.0.1"
  },

  "build": {
    "appId": "com.fluxenite.gat",
    "productName": "GAT",

    "directories": {
      "output": "release",
      "buildResources": "src/assets"
    },

    "files": [
      "dist/**/*",
      "src/assets/**/*",
      "backend/gat-backend.exe",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],

    "asar": true,

    "icon": "src/assets/icon.ico",

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GAT"
    }
  }
}